<div class="relative w-full">
  <%= image_tag "battle.png", alt: "たいきょくがめん", class: "w-full" %>

  <div class="absolute top-[calc(50%+10px)] left-1/2 -translate-x-1/2 -translate-y-1/2 w-1/2">
    <%= image_tag "onegaishimasu.png", alt: "おねがいします", class: "w-full h-auto" %>
  </div>
</div>

<div class="text-sm">
  <p>ターン: <%= @turn %></p>
  <p>次の頭文字: <%= @last_word&.[](-1) %></p>
  <p>使った単語: <%= @used_words.join("、") %></p>
  <% if @error %>
    <p class="text-red-600"><%= @error %></p>
  <% end %>
  <% if @result == :lose %>
    <p class="text-red-600">「ん」で終わったので負けです</p>
  <% end %>
</div>

<%= form_with url: shiritori_answer_path, method: :post do %>
  <%= text_field_tag :word, nil %>
  <%= submit_tag "こたえる" %>
<% end %>

<div class="flex w-full gap-4">
  <%= link_to user_path(current_user), data: { turbo_method: :delete }, class: "w-1/2" do %>
    <%= image_tag "owari.png", alt: "おわり", class: "w-full h-auto" %>
  <% end %>

  <%= link_to restart_users_path, data: { turbo_method: :post }, class: "w-1/2" do %>
    <%= image_tag "mouichido.png", alt: "もういちど", class: "w-full h-auto" %>
  <% end %>
</div>
